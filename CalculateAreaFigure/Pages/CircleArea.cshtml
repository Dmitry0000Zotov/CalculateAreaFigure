@page
@model CalculateAreaFigure.Pages.CircleAreaModel
@{
    Layout = "_Layout";
}
<div class="container">
    <h1 class="fs-3">Calculate Circle Area</h1>
    <form method="post">
        <div class="container">
            <div class="row">
                <div class="col">
                    <h1 class="fs-5">Enter data:</h1>
                    <div class="input-group mb-3 w-50">
                        <span class="input-group-text" id="basic-addon1">Circle radius</span>
                        <input type="number" name="radius" class="form-control" placeholder="Radius" aria-label="Circle radius" aria-describedby="basic-addon1">
                    </div>
                    <input class="btn btn-outline-success" type="submit" value="Submit"></input>
                </div>
                <div class="col">
                    @if (Model.CircleArea != 0)
                    {
                        <div class="container">
                            <h1 class="fs-5">Calculated circle area: @Model.CircleArea</h1>
                        </div>
                    }
                    else
                    {
                        <div class="container text-danger">
                            <h1 class="fs-5">@Model.Message</h1>
                        </div>
                    }
                </div>
            </div>
        </div>
    </form>
</div>